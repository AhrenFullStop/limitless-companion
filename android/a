/**
 * Database entity representing a transcript segment.
 * 
 * @property id Primary key
 * @property sessionId Foreign key to session
 * @property text Transcribed text
 * @property timestamp When the transcript was created
 * @property startTimeMs Start time in milliseconds (relative to session start)
 * @property endTimeMs End time in milliseconds (relative to session start)
 * @property confidence Transcription confidence score (0.0 to 1.0)
 * @property language Language code
 * @property speakerId Speaker identifier (null if not identified)
 * @property isSynced Whether this transcript has been uploaded to server
 * @property serverId Server-side ID (null if not synced)
 * @property retryCount Number of sync attempts
 * @property createdAt Record creation timestamp
 * @property updatedAt Record last update timestamp
 */
@Entity(
    tableName = "transcripts",
    foreignKeys = [
        ForeignKey(
            entity = SessionEntity::class,
            parentColumns = ["id"],
            childColumns = ["session_id"],
            onDelete = CASCADE
        )
    ],
    indices = [
        Index(value = ["session_id"]),
        Index(value = ["timestamp"]),
        Index(value = ["is_synced"]),
        Index(value = ["server_id"], unique = true)
    ]
)
data class TranscriptEntity(
    @PrimaryKey(autoGenerate = true)
    val id: Long = 0,

    @ColumnInfo(name = "session_id")
    val sessionId: String,

    @ColumnInfo(name = "text")
    val text: String,

    @ColumnInfo(name = "timestamp")
    val timestamp: Long = System.currentTimeMillis(),

    @ColumnInfo(name = "start_time_ms")
    val startTimeMs: Long = 0,

    @ColumnInfo(name = "end_time_ms")
    val endTimeMs: Long = 0,

    @ColumnInfo(name = "confidence")
    val confidence: Float = 0.0f,

    @ColumnInfo(name = "language")
    val language: String = "en",

    @ColumnInfo(name = "speaker_id")
    val speakerId: String? = null,

    @ColumnInfo(name = "is_synced")
    val isSynced: Boolean = false,

    @ColumnInfo(name = "server_id")
    val serverId: String? = null,

    @ColumnInfo(name = "retry_count")
    val retryCount: Int = 0,

    @ColumnInfo(name = "created_at")
    val createdAt: Long = System.currentTimeMillis(),

    @ColumnInfo(name = "updated_at")
    val updatedAt: Long = System.currentTimeMillis()
)

/**
 * Database entity representing a recording session.
 * 
 * @property id Primary key (session UUID)
 * @property startTime Session start timestamp
 * @property endTime Session end timestamp (null if active)
 * @property durationMs Total session duration in milliseconds
 * @property transcriptCount Number of transcript segments
 * @property deviceInfo Device information
 * @property bluetoothDeviceName Bluetooth device name
 * @property isActive Whether session is currently active
 * @property isSynced Whether session has been uploaded to server
 * @property serverId Server-side ID (null if not synced)
 * @property createdAt Record creation timestamp
 * @property updatedAt Record last update timestamp
 */
@Entity(
    tableName = "sessions",
    indices = [
        Index(value = ["start_time"]),
        Index(value = ["is_active"]),
        Index(value = ["is_synced"]),
        Index(value = ["server_id"], unique = true)
    ]
)
data class SessionEntity(
    @PrimaryKey
    val id: String,

    @ColumnInfo(name = "start_time")
    val startTime: Long,

    @ColumnInfo(name = "end_time")
    val endTime: Long? = null,

    @ColumnInfo(name = "duration_ms")
    val durationMs: Long = 0,

    @ColumnInfo(name = "transcript_count")
    val transcriptCount: Int = 0,

    @ColumnInfo(name = "device_info")
    val deviceInfo: String = "",

    @ColumnInfo(name = "bluetooth_device_name")
    val bluetoothDeviceName: String? = null,

    @ColumnInfo(name = "is_active")
    val isActive: Boolean = true,

    @ColumnInfo(name = "is_synced")
    val isSynced: Boolean = false,

    @ColumnInfo(name = "server_id")
    val serverId: String? = null,

    @ColumnInfo(name = "created_at")
    val createdAt: Long = System.currentTimeMillis(),

    @ColumnInfo(name = "updated_at")
    val updatedAt: Long = System.currentTimeMillis()
)

