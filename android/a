/**
 * DAO for transcript operations.
 */
@Dao
interface TranscriptDao {

    /**
     * Inserts a new transcript.
     * 
     * @param transcript Transcript to insert
     * @return Row ID of inserted transcript
     */
    @Insert(onConflict = OnConflictStrategy.REPLACE)
    suspend fun insert(transcript: TranscriptEntity): Long

    /**
     * Inserts multiple transcripts.
     * 
     * @param transcripts Transcripts to insert
     * @return List of row IDs
     */
    @Insert(onConflict = OnConflictStrategy.REPLACE)
    suspend fun insertAll(transcripts: List<TranscriptEntity>): List<Long>

    /**
     * Updates a transcript.
     * 
     * @param transcript Transcript to update
     */
    @Update
    suspend fun update(transcript: TranscriptEntity)

    /**
     * Deletes a transcript.
     * 
     * @param transcript Transcript to delete
     */
    @Delete
    suspend fun delete(transcript: TranscriptEntity)

    /**
     * Gets a transcript by ID.
     * 
     * @param id Transcript ID
     * @return Transcript or null
     */
    @Query("SELECT * FROM transcripts WHERE id = :id")
    suspend fun getById(id: Long): TranscriptEntity?

    /**
     * Gets all transcripts for a session.
     * 
     * @param sessionId Session ID
     * @return Flow of transcripts
     */
    @Query("SELECT * FROM transcripts WHERE session_id = :sessionId ORDER BY timestamp ASC")
    fun getBySession(sessionId: String): Flow<List<TranscriptEntity>>

    /**
     * Gets all unsynced transcripts.
     * 
     * @return Flow of unsynced transcripts
     */
    @Query("SELECT * FROM transcripts WHERE is_synced = 0 ORDER BY timestamp ASC")
    fun getUnsynced(): Flow<List<TranscriptEntity>>

    /**
     * Gets unsynced transcripts that haven't exceeded retry limit.
     * 
     * @param maxRetries Maximum retry count
     * @return List of transcripts
     */
    @Query("SELECT * FROM transcripts WHERE is_synced = 0 AND retry_count < :maxRetries ORDER BY timestamp ASC")
    suspend fun getUnsyncedWithRetries(maxRetries: Int): List<TranscriptEntity>

    /**
     * Marks a transcript as synced.
     * 
     * @param id Transcript ID
     * @param serverId Server-side ID
     */
    @Query("UPDATE transcripts SET is_synced = 1, server_id = :serverId, updated_at = :updatedAt WHERE id = :id")
    suspend fun markAsSynced(id: Long, serverId: String, updatedAt: Long = System.currentTimeMillis())

    /**
     * Increments retry count for a transcript.
     * 
     * @param id Transcript ID
     */
    @Query("UPDATE transcripts SET retry_count = retry_count + 1, updated_at = :updatedAt WHERE id = :id")
    suspend fun incrementRetryCount(id: Long, updatedAt: Long = System.currentTimeMillis())

    /**
     * Searches transcripts by text.
     * 
     * @param query Search query
     * @return Flow of matching transcripts
     * 
     * TODO(milestone-2): Implement with FTS for better performance
     */
    @Query("SELECT * FROM transcripts WHERE text LIKE '%' || :query || '%' ORDER BY timestamp DESC")
    fun search(query: String): Flow<List<TranscriptEntity>>

    /**
     * Gets transcripts within a time range.
     * 
     * @param startTime Start timestamp
     * @param endTime End timestamp
     * @return Flow of transcripts
     */
    @Query("SELECT * FROM transcripts WHERE timestamp BETWEEN :startTime AND :endTime ORDER BY timestamp ASC")
    fun getByTimeRange(startTime: Long, endTime: Long): Flow<List<TranscriptEntity>>

    /**
     * Deletes all transcripts for a session.
     * 
     * @param sessionId Session ID
     */
    @Query("DELETE FROM transcripts WHERE session_id = :sessionId")
    suspend fun deleteBySession(sessionId: String)

    /**
     * Deletes all synced transcripts older than a timestamp.
     * 
     * @param timestamp Cutoff timestamp
     * @return Number of deleted rows
     */
    @Query("DELETE FROM transcripts WHERE is_synced = 1 AND timestamp < :timestamp")
    suspend fun deleteSyncedOlderThan(timestamp: Long): Int

    /**
     * Gets total count of transcripts.
     * 
     * @return Total count
     */
    @Query("SELECT COUNT(*) FROM transcripts")
    suspend fun getCount(): Int

    /**
     * Gets count of unsynced transcripts.
     * 
     * @return Unsynced count
     */
    @Query("SELECT COUNT(*) FROM transcripts WHERE is_synced = 0")
    suspend fun getUnsyncedCount(): Int
}

/**
 * DAO for session operations.
 */
@Dao
interface SessionDao {

    /**
     * Inserts a new session.
     * 
     * @param session Session to insert
     */
    @Insert(onConflict = OnConflictStrategy.REPLACE)
    suspend fun insert(session: SessionEntity)

    /**
     * Updates a session.
     * 
     * @param session Session to update
     */
    @Update
    suspend fun update(session: SessionEntity)

    /**
     * Deletes a session.
     * 
     * @param session Session to delete
     */
    @Delete
    suspend fun delete(session: SessionEntity)

    /**
     * Gets a session by ID.
     * 
     * @param id Session ID
     * @return Session or null
     */
    @Query("SELECT * FROM sessions WHERE id = :id")
    suspend fun getById(id: String): SessionEntity?

    /**
     * Gets all sessions.
     * 
     * @return Flow of all sessions
     */
    @Query("SELECT * FROM sessions ORDER BY start_time DESC")
    fun getAll(): Flow<List<SessionEntity>>

    /**
     * Gets active session.
     * 
     * @return Active session or null
     */
    @Query("SELECT * FROM sessions WHERE is_active = 1 LIMIT 1")
    suspend fun getActive(): SessionEntity?

    /**
     * Gets all unsynced sessions.
     * 
     * @return Flow of unsynced sessions
     */
    @Query("SELECT * FROM sessions WHERE is_synced = 0 ORDER BY start_time DESC")
    fun getUnsynced(): Flow<List<SessionEntity>>

    /**
     * Marks a session as synced.
     * 
     * @param id Session ID
     * @param serverId Server-side ID
     */
    @Query("UPDATE sessions SET is_synced = 1, server_id = :serverId, updated_at = :updatedAt WHERE id = :id")
    suspend fun markAsSynced(id: String, serverId: String, updatedAt: Long = System.currentTimeMillis())

    /**
     * Marks a session as inactive.
     * 
     * @param id Session ID
     * @param endTime End timestamp
     * @param durationMs Duration in milliseconds
     */
    @Query("UPDATE sessions SET is_active = 0, end_time = :endTime, duration_ms = :durationMs, updated_at = :updatedAt WHERE id = :id")
    suspend fun markAsInactive(
        id: String,
        endTime: Long,
        durationMs: Long,
        updatedAt: Long = System.currentTimeMillis()
    )

    /**
     * Updates transcript count for a session.
     * 
     * @param id Session ID
     * @param count New transcript count
     */
    @Query("UPDATE sessions SET transcript_count = :count, updated_at = :updatedAt WHERE id = :id")
    suspend fun updateTranscriptCount(id: String, count: Int, updatedAt: Long = System.currentTimeMillis())

    /**
     * Deletes sessions older than a timestamp.
     * 
     * @param timestamp Cutoff timestamp
     * @return Number of deleted rows
     */
    @Query("DELETE FROM sessions WHERE is_synced = 1 AND start_time < :timestamp")
    suspend fun deleteSyncedOlderThan(timestamp: Long): Int

    /**
     * Gets total count of sessions.
     * 
     * @return Total count
     */
    @Query("SELECT COUNT(*) FROM sessions")
    suspend fun getCount(): Int
}

