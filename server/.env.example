# Limitless Companion - Environment Configuration
# Copy this file to .env and customize for your deployment

# ============================================
# Server Configuration
# ============================================

# Server host and port
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# Public URL for the server (used by mobile app)
# For local testing: http://192.168.1.100:8000
# For production: https://your-domain.com
SERVER_URL=https://your-server.com

# Enable HTTPS (recommended for production)
HTTPS_ENABLED=true

# ============================================
# Database Configuration
# ============================================

# PostgreSQL connection settings
POSTGRES_USER=limitless
POSTGRES_PASSWORD=change-this-secure-password
POSTGRES_DB=limitless_db
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Database URL (constructed automatically, don't modify)
# DATABASE_URL=postgresql://limitless:change-this-secure-password@db:5432/limitless_db

# ============================================
# LLM Configuration (Ollama)
# ============================================

# Ollama service host (Docker service name)
OLLAMA_HOST=http://ollama:11434

# Model for action detection (Llama 3.1 8B recommended)
OLLAMA_MODEL=llama3.1:8b

# Alternative smaller model for resource-constrained servers
# OLLAMA_MODEL=llama3.2:3b

# ============================================
# Embedding Model (for RAG Search)
# ============================================

# Sentence transformer model for transcript embeddings
# Options: all-MiniLM-L6-v2 (faster), all-mpnet-base-v2 (more accurate)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ============================================
# Action Detection Settings
# ============================================

# Confidence threshold for action notifications (0.0-1.0)
ACTION_DETECTION_CONFIDENCE=0.7

# Batch size for processing transcripts
ACTION_DETECTION_BATCH_SIZE=5

# Maximum actions to detect per minute (rate limiting)
ACTION_DETECTION_RATE_LIMIT=10

# ============================================
# Speaker Diarization Settings
# ============================================

# Enable/disable speaker diarization
SPEAKER_DIARIZATION_ENABLED=true

# Diarization method: 'pyannote' or 'heuristic'
SPEAKER_DIARIZATION_METHOD=pyannote

# ============================================
# Data Retention & Storage
# ============================================

# Days to retain transcripts (default: 90 days)
TRANSCRIPT_RETENTION_DAYS=90

# Maximum transcript length for processing (characters)
MAX_TRANSCRIPT_LENGTH=10000

# ============================================
# Security Settings
# ============================================

# API Key settings
API_KEY_LENGTH=32
API_KEY_PREFIX=sk_live_

# Request rate limiting
RATE_LIMIT_REQUESTS_PER_HOUR=1000

# ============================================
# Logging Configuration
# ============================================

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Enable structured JSON logging
LOG_JSON_FORMAT=true

# ============================================
# Development Settings
# ============================================

# Enable debug mode (don't use in production)
DEBUG=false

# Enable CORS for development (don't use in production)
CORS_ENABLED=false

# ============================================
# Optional: External Services
# ============================================

# Fallback Whisper API (OpenAI) - leave empty to disable
# OPENAI_API_KEY=sk-your-openai-key-here

# ============================================
# Docker & Deployment
# ============================================

# Docker image tags
SERVER_IMAGE_TAG=latest
OLLAMA_IMAGE_TAG=latest
DB_IMAGE_TAG=latest

# Restart policies
SERVER_RESTART_POLICY=unless-stopped
OLLAMA_RESTART_POLICY=unless-stopped
DB_RESTART_POLICY=unless-stopped