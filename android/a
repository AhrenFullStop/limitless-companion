/**
 * Type converters for Room database.
 * 
 * Room requires type converters for types it doesn't natively support.
 */
class DatabaseConverters {

    /**
     * Converts Date to Long timestamp.
     */
    @TypeConverter
    fun fromDate(date: Date?): Long? {
        return date?.time
    }

    /**
     * Converts Long timestamp to Date.
     */
    @TypeConverter
    fun toDate(timestamp: Long?): Date? {
        return timestamp?.let { Date(it) }
    }

    /**
     * Converts List<String> to comma-separated string.
     */
    @TypeConverter
    fun fromStringList(list: List<String>?): String? {
        return list?.joinToString(",")
    }

    /**
     * Converts comma-separated string to List<String>.
     */
    @TypeConverter
    fun toStringList(data: String?): List<String>? {
        return data?.split(",")?.filter { it.isNotEmpty() }
    }
}

