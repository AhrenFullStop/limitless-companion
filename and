# CMakeLists.txt
# 
# CMake configuration for building the Whisper Android JNI library.
# 
# This file configures the native build for the whisper_android native library,
# which provides JNI bindings to whisper.cpp for Android.
# 
# Build requirements:
# - CMake 3.18.1 or higher
# - Android NDK
# - C++17 support
# 
# TODO(milestone-1): Add whisper.cpp library as a dependency
# TODO(milestone-1): Configure proper include paths for whisper.cpp
# TODO(milestone-2): Add GPU acceleration support (NNAPI, Vulkan, OpenCL)
# TODO(milestone-2): Add build variants for different architectures

cmake_minimum_required(VERSION 3.18.1)

project("whisper_android" LANGUAGES CXX)

# ============================================================================
# Compiler Configuration
# ============================================================================

# Set C++ standard
set(CMAKE_CXX_STANDARD 17)
set(CMAKE_CXX_STANDARD_REQUIRED ON)
set(CMAKE_CXX_EXTENSIONS OFF)

# Compiler flags
set(CMAKE_CXX_FLAGS "${CMAKE_CXX_FLAGS} -Wall -Wextra -Werror")
set(CMAKE_CXX_FLAGS_RELEASE "${CMAKE_CXX_FLAGS_RELEASE} -O3 -DNDEBUG")
set(CMAKE_CXX_FLAGS_DEBUG "${CMAKE_CXX_FLAGS_DEBUG} -O0 -g")

# Enable position independent code
set(CMAKE_POSITION_INDEPENDENT_CODE ON)

# ============================================================================
# Source Files
# ============================================================================

# Native library source files
set(NATIVE_SRCS
    whisper_android.cpp
)

# TODO(milestone-1): Add whisper.cpp source files when library is integrated
# set(WHISPER_SRCS
#     ${CMAKE_SOURCE_DIR}/whisper.cpp/whisper.cpp
#     ${CMAKE_SOURCE_DIR}/whisper.cpp/ggml.c
# )

# ============================================================================
# Include Directories
# ============================================================================

# Include directories for this project
include_directories(
    ${CMAKE_SOURCE_DIR}
)

# TODO(milestone-1): Add whisper.cpp include directory
# include_directories(
#     ${CMAKE_SOURCE_DIR}/whisper.cpp
# )

# ============================================================================
# Native Library Target
# ============================================================================

# Create the shared library
add_library(
    whisper_android
    SHARED
    ${NATIVE_SRCS}
    # ${WHISPER_SRCS}  # TODO: Uncomment when whisper.cpp is added
)

# ============================================================================
# Link Libraries
# ============================================================================

# Find required Android libraries
find_library(log-lib log)
find_library(android-lib android)

# Link against Android libraries
target_link_libraries(
    whisper_android
    ${log-lib}
    ${android-lib}
)

# TODO(milestone-1): Link against whisper.cpp library
