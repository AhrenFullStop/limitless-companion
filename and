# ============================================================================

# Option to enable verbose logging
option(WHISPER_DEBUG_LOGGING "Enable debug logging" ON)
if(WHISPER_DEBUG_LOGGING)
    target_compile_definitions(whisper_android PRIVATE WHISPER_DEBUG)
endif()

# Option to enable performance profiling
option(WHISPER_PROFILE "Enable performance profiling" OFF)
if(WHISPER_PROFILE)
    target_compile_definitions(whisper_android PRIVATE WHISPER_PROFILE)
endif()

